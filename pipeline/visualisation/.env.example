# Copy to .env and fill in. All values are optional — the pipeline runs offline
# without any of them.

# Gemini API key for the photorealistic render step. If unset, a mock render
# is produced instead.
GEMINI_API_KEY=

# Optional: override the Gemini image model.
# GEMINI_MODEL=gemini-2.0-flash-preview-image-generation

# Optional: point at a different comparative table (Stage 3 output).
# COMPARATIVE_TABLE=../SURROUND_UPFRONT-CARBON-bhavana (1)/SURROUND_UPFRONT-CARBON-bhavana/output/comparative_table.csv
