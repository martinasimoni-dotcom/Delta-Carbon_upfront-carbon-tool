# Root .env.example — all variables used across the project
# Copy the relevant section into the matching subfolder's .env

# ── frontend/.env ─────────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ── backend/.env ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
EPD_API_TOKEN=your_epd_api_token_here

# ── pipeline/visualisation/.env (optional) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
COMPARATIVE_TABLE=../epd/output/comparative_table.csv
