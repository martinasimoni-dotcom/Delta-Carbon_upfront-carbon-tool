# Anthropic API key — for Claude claude-sonnet-4-6 LLM calls in /v1/suggestions
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 2050-materials EPD API token — for BEDEC/ITeC EPD lookups, country=ES
# Get from: app.2050-materials.com → Profile → Developer Token
EPD_API_TOKEN=your_epd_api_token_here

# OpenAI API key — for DALL-E 3 architectural renders in /v1/render
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=your_openai_api_key_here
