# Google Maps API key
# Enable: Maps JavaScript API, Places API, Distance Matrix API
# Get from: console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"


# Mapbox token — for the site location map (MapView, MapInfoSection, SupplierMapPanel)
# Get from: account.mapbox.com → Tokens
VITE_MAPBOX_TOKEN="your_mapbox_token_here"
